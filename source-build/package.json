{
  "name": "bin-afif-office",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev:next":     "next dev",
    "dev:electron": "cross-env NODE_ENV=development wait-on tcp:3000 && electron .",
    "dev":          "concurrently -k -n \"Next,Electron\" -c \"blue,green\" \"npm run dev:next\" \"npm run dev:electron\"",
    "build:next":   "next build",
    "pack":         "npm run build:next && electron-builder --dir",
    "dist":         "npm run build:next && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.378.0",
    "next":         "15.5.15",
    "react":        "^18.3.1",
    "react-dom":    "^18.3.1"
  },
  "devDependencies": {
    "@types/node":      "^22.0.0",
    "@types/react":     "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "autoprefixer":     "^10.4.19",
    "concurrently":     "^8.2.2",
    "cross-env":        "^7.0.3",
    "electron":         "^35.0.0",
    "electron-builder": "^24.13.3",
    "postcss":          "^8.4.38",
    "tailwindcss":      "^3.4.3",
    "typescript":       "^5.4.5",
    "wait-on":          "^7.2.0"
  },
  "build": {
    "appId":       "com.binafif.office",
    "productName": "مكتب بلس",
    "copyright":   "جميع الحقوق محفوظة",
    "asar":        true,
    "forceCodeSigning": false,
    "directories": { "output": "dist" },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      { "from": ".next/standalone",     "to": "server",             "filter": ["**/*"] },
      { "from": ".next/static",         "to": "server/.next/static", "filter": ["**/*"] },
      { "from": "public",               "to": "server/public",       "filter": ["**/*"] }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "sign": false,
      "signAndEditExecutable": false,
      "signingHashAlgorithms": []
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "linux": { "target": ["AppImage"] },
    "mac":   { "target": ["dmg"] }
  }
}
